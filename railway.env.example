# doniapp-back — Railway Variables (Dashboard → Variables)
# Postgres: servisni backend ga Connect → DATABASE_URL avtomatik reference

# === Majburiy ===
DJANGO_DEBUG=0
DJANGO_SECRET_KEY=<openssl rand -hex 32>
# DATABASE_URL=${{Postgres.DATABASE_URL}}   # reference — qo'lda yozmang

# === Telegram ===
TELEGRAM_BOT_TOKEN=<BotFather token>
TELEGRAM_NOTIFY_CHAT_ID=-1003942993894

# === CORS (ixtiyoriy, Railway regex ham ishlaydi) ===
# CORS_EXTRA_ORIGINS=https://doniapp-front-production.up.railway.app
# CSRF_TRUSTED_EXTRA=https://doniapp-front-production.up.railway.app

# === Avtomatik (Railway beradi) ===
# RAILWAY_ENVIRONMENT=production
# RAILWAY_PUBLIC_DOMAIN=doniapp-back-production.up.railway.app
# PORT=8080

# Qo'lda DATABASE_PUBLIC_URL backendga QO'YMANG (faqat private DATABASE_URL)
