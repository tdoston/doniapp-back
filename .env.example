# ─── Environment ────────────────────────────────────────────────────────────
# "local" | "staging" | "production"
DJANGO_ENV=local

# ─── Security ────────────────────────────────────────────────────────────────
# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=dev-only-insecure-secret-change-me

# ─── Hosts ───────────────────────────────────────────────────────────────────
# Comma-separated. Railway appends .up.railway.app automatically when DJANGO_ENV != local.
ALLOWED_HOSTS=127.0.0.1,localhost

# ─── Database ────────────────────────────────────────────────────────────────
# Local (Docker or Homebrew Postgres):
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/swift_bookings

# Railway: set this in Railway service Variables — copy from Postgres plugin → Connect → Private URL
# DATABASE_URL=postgresql://postgres:<password>@<host>.railway.internal:5432/railway

# ─── CORS & CSRF ─────────────────────────────────────────────────────────────
# Add your frontend URLs (comma-separated, with scheme)
CORS_EXTRA_ORIGINS=https://your-frontend.up.railway.app
CSRF_TRUSTED_ORIGINS=https://your-frontend.up.railway.app

# ─── Admin superuser ─────────────────────────────────────────────────────────
# Used by: python manage.py seed_defaults  (and  ensure_admin)
DJANGO_ADMIN_USERNAME=admin
DJANGO_ADMIN_EMAIL=admin@example.com
DJANGO_ADMIN_PASSWORD=change-me-in-production

# ─── Telegram bot (optional) ─────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=

# ─── OpenAI document parser (optional) ───────────────────────────────────────
# OPENAI_API_KEY=
# OPENAI_DOC_PARSER_MODEL=gpt-4o
