# ─── Environment ─────────────────────────────────────────────────────────────
# "local" | "staging" | "production"
DJANGO_ENV=local

# ─── Security ─────────────────────────────────────────────────────────────────
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=dev-only-insecure-secret-change-me

# ─── Database ─────────────────────────────────────────────────────────────────
# Local:
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/swift_bookings
# Railway: set ${{Postgres.DATABASE_URL}} in service Variables

# ─── Hosts / CORS / CSRF ──────────────────────────────────────────────────────
ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=https://your-frontend-staging.up.railway.app
CSRF_TRUSTED_ORIGINS=https://your-frontend-staging.up.railway.app

# ─── Superuser (used by seed_defaults) ───────────────────────────────────────
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me-in-production

# ─── Telegram (optional) ──────────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=

# ─── OpenAI (optional) ────────────────────────────────────────────────────────
# OPENAI_API_KEY=
