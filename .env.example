# SQLite (ixtiyoriy yo'l)
# SQLITE_PATH=

# Telegram bot (faqat serverda; Mini App frontendda token bo'lmaydi)
# TELEGRAM_BOT_TOKEN=

# ngrok public tunnel (https://dashboard.ngrok.com/get-started/your-authtoken)
# NGROK_AUTHTOKEN=

# Passport/ID OCR: PassportEye (MRZ) + zaxira Tesseract. Tizimda: brew install tesseract tesseract-lang
# TESSERACT_CMD=/opt/homebrew/bin/tesseract
# TESSERACT_LANGS=eng+rus
# MRZ uchun legacy tessdata: PASSPORTEYE_TESSERACT_PARAMS=--oem 0

# OpenAI hujjat parser (birinchi yuklangan hujjat rasmi)
# OPENAI_API_KEY=
# OPENAI_DOC_PARSER_MODEL=gpt-5.4
